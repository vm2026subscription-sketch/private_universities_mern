PORT=5000

# IMPORTANT: security settings FAIL CLOSED. Anything other than an explicit
# development value (development / dev / test / local) is treated as production,
# so an unset NODE_ENV keeps Secure cookies, HSTS and strict secret checks ON.
# Set this to development for local work or Secure cookies will not be sent
# over plain http://localhost.
NODE_ENV=development

MONGODB_URI=mongodb://127.0.0.1:27017/vidyarthi-mitra

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate each secret independently:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#
# Startup ABORTS if a secret is a known placeholder, or is shorter than 32
# characters outside development. All three secrets MUST differ from one
# another; any not set is derived from JWT_ACCESS_SECRET via domain-separated
# HMAC, which preserves token-type separation but is weaker than independent
# random values. Set all three explicitly in production.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Signs the short-lived challenge issued between the password and OTP steps.
# It MUST NOT share the access secret: doing so lets the challenge be replayed
# as a Bearer token, authenticating on the password alone and skipping the OTP.
JWT_MFA_SECRET=

# Legacy variable. Still read as a fallback for JWT_ACCESS_SECRET and used to
# validate tokens issued before the auth refactor. Keep it set until the old
# 30-day tokens have expired, then remove it along with ALLOW_LEGACY_TOKENS.
JWT_SECRET=

# Asserted on every token verification.
JWT_ISSUER=vidyarthi-mitra-api
JWT_AUDIENCE=vidyarthi-mitra-client

# Short access token + long rotating refresh token.
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d
JWT_MFA_EXPIRE=5m

# Accept pre-refactor tokens so the deploy does not log everyone out.
# Set to false once JWT_EXPIRE's old window (30d) has elapsed.
ALLOW_LEGACY_TOKENS=true

# bcrypt cost factor (10-15). Raising it transparently upgrades each account's
# hash on their next successful login.
BCRYPT_ROUNDS=12

# Peppers the stored OTP hashes. Without it the access secret is used.
OTP_PEPPER=

# DANGEROUS — local development only. When true, failed email delivery returns
# the verification code / password-reset URL in the API response body. Startup
# ABORTS if this is true while NODE_ENV=production.
ALLOW_DEV_OTP_ECHO=false

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Email (Resend alternative)
RESEND_API_KEY=your_resend_api_key
# In production, use a verified sender/domain. The default onboarding@resend.dev
# address only works for limited test recipients on Resend.
RESEND_FROM=Vidyarthi Mitra <noreply@yourdomain.com>

# OTP Provider: twilio_verify or msg91
OTP_PROVIDER=twilio_verify

# Twilio (SMS & WhatsApp OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
TWILIO_PHONE_NUMBER=your_twilio_phone_number
TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number

# MSG91 (optional)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id


# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
# gemini-1.5-* models are RETIRED (404). On the free tier, gemini-flash-latest
# is capped at ~20 req/day; gemini-flash-lite-latest has a far higher free quota.
GEMINI_MODEL=gemini-flash-lite-latest

# ── Admin ──────────────────────────────────────────────────────────────────
# ADMIN_EMAIL no longer grants any privilege. Roles live exclusively in the
# database and are assigned out-of-band:
#
#   node scripts/grantRole.js --list
#   node scripts/grantRole.js --email you@example.com --role admin --confirm
#
# This variable is now only the destination for operational notification emails.
ADMIN_EMAIL=

CLIENT_URL=http://localhost:5173
