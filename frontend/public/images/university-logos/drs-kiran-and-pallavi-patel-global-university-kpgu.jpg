    <script id="custom-gallery-observer">
        const animationSelectors = [
            '.gallery-section img',
            '.gallery-section .section-title',
            '.gallery-section .button-wrap',
            '.gallery-section .text-20px-regular',
            '.gallery-section .gallery-card',
            '.blog-section-lp-02 .section-title-content',
            '.blog-section-lp-02 .section-title-action',
            '.blog-section-lp-02 .blog-card-link',
            '.animate-on-scroll',
            '.animate-fade-in'
        ].join(', ');

        const galleryObserver = new IntersectionObserver((entries) => {
            let delay = 0;
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    setTimeout(() => {
                        entry.target.classList.add('scroll-anim-visible');
                    }, delay * 120);
                    delay++;
                    galleryObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

        const observeNewElements = () => {
            const elements = document.querySelectorAll(animationSelectors);
            elements.forEach(el => {
                if (!el.dataset.mapped) {
                    galleryObserver.observe(el);
                    el.dataset.mapped = 'true';
                }
            });
        };

        /**
         * Called by the React useScrollAnimation hook on every route change.
         * Resets scroll-anim-visible so animations replay when returning to a page.
         */
        const resetAndReobserve = () => {
            // Remove visible class & mapped flag so observer re-triggers everything
            document.querySelectorAll('.scroll-anim-visible').forEach(el => {
                el.classList.remove('scroll-anim-visible');
            });
            document.querySelectorAll('[data-mapped]').forEach(el => {
                delete el.dataset.mapped;
            });
            // Small tick so the DOM settles before re-observing
            requestAnimationFrame(() => {
                observeNewElements();
            });
        };

        // Expose globally for React hook access
        window.observeNewElements = observeNewElements;
        window.resetAndReobserve = resetAndReobserve;

        document.addEventListener("DOMContentLoaded", function () {
            const rootNode = document.getElementById('root');
            if (rootNode) {
                const domObserver = new MutationObserver(() => {
                    observeNewElements();
                });
                domObserver.observe(rootNode, { childList: true, subtree: true });
            }
            observeNewElements();
        });
    </script>

